{
  "api_name": "blocket",
  "base_url": "https://www.blocket.se",
  "description": "Blocket — Sweden's largest second-hand marketplace (BAP general + mobility).",
  "mcp_ready": "full",
  "http_transport": "browser-chrome",
  "auth": {
    "type": "none"
  },
  "required_headers": [],
  "tools": [
    {
      "name": "ads_get",
      "description": "Fetch full detail for a BAP listing. Required: ad_id. Returns the AdDetail.",
      "method": "GET",
      "path": "/recommerce/forsale/item/{ad_id}",
      "no_auth": true,
      "params": [
        {
          "name": "ad_id",
          "type": "string",
          "location": "path",
          "description": "Blocket ad id.",
          "required": true
        }
      ]
    },
    {
      "name": "ads_list",
      "description": "List general BAP listings (SEARCH_ID_BAP_COMMON). Optional: query, category, location (plus 10 more). Returns the SearchResponse.",
      "method": "GET",
      "path": "/recommerce/forsale/search/api/search/SEARCH_ID_BAP_COMMON",
      "no_auth": true,
      "params": [
        {
          "name": "query",
          "wire_name": "q",
          "type": "string",
          "location": "query",
          "description": "Free-text query against listing headings."
        },
        {
          "name": "category",
          "type": "string",
          "location": "query",
          "description": "Hierarchical category id (e.g. 0.91, 1.91.3108, 2.91.3108.362)."
        },
        {
          "name": "location",
          "type": "string",
          "location": "query",
          "description": "Swedish region/county id; repeat by comma-separating values."
        },
        {
          "name": "radius",
          "type": "int",
          "location": "query",
          "description": "Radius in km when combined with a location seed."
        },
        {
          "name": "trade_type",
          "type": "string",
          "location": "query",
          "description": "Seller intent — Säljes (selling), Köpes (buying), Bortskänkes (giving away)."
        },
        {
          "name": "price_from",
          "type": "int",
          "location": "query",
          "description": "Minimum price in SEK."
        },
        {
          "name": "price_to",
          "type": "int",
          "location": "query",
          "description": "Maximum price in SEK."
        },
        {
          "name": "dealer_segment",
          "type": "string",
          "location": "query",
          "description": "Filter by dealer segment (private vs dealer)."
        },
        {
          "name": "condition",
          "type": "string",
          "location": "query",
          "description": "Listing condition — new, used, broken, etc."
        },
        {
          "name": "shipping_types",
          "type": "string",
          "location": "query",
          "description": "Filter by shipping option (e.g. with-shipping, pickup-only)."
        },
        {
          "name": "published",
          "type": "string",
          "location": "query",
          "description": "Recency filter (e.g. last_24h, last_week)."
        },
        {
          "name": "sort",
          "type": "string",
          "location": "query",
          "description": "Sort order (default newest)."
        },
        {
          "name": "page",
          "type": "int",
          "location": "query",
          "description": "Page number (1-based, 50 results per page)."
        }
      ]
    },
